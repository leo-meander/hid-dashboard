# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudbeds
CLOUDBEDS_API_KEY=your_cloudbeds_api_key
# Comma-separated JSON: [{"branch_id": "uuid", "property_id": "123"}]
CLOUDBEDS_PROPERTY_IDS=[{"branch_id":"<uuid>","property_id":"<cloudbeds_id>"}]

# Exchange Rate API (https://www.exchangerate-api.com)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# Ads Platform API (Meander internal — replaces Meta Graph API + Google Sheets ads)
# Auth via X-API-Key header. Rate limit: 1000 req/day/key.
ADS_PLATFORM_BASE_URL=https://ads-performance-fuls.zeabur.app
ADS_PLATFORM_API_KEY=your_ads_platform_api_key

# Google OAuth (used by KOL sheet sync + GHL email sync — NOT for ads anymore)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# KOL Media Engine
KOL_ENGINE_URL=https://kol-media-engine.zeabur.app
KOL_ENGINE_ORG_ID=your_org_id
KOL_SYNC_API_KEY=your_kol_sync_api_key

# App
APP_ENV=development
SECRET_KEY=changeme_use_a_long_random_string
FRONTEND_URL=https://your-zeabur-domain.zeabur.app

# Shared secret for GitHub Actions cron workflows (required header X-Sync-Token).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the check (dev only — never empty in production).
SYNC_TRIGGER_TOKEN=changeme_random_secret
